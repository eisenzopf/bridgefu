# Copy to terraform.tfvars and edit. Run from terraform/.

region = "us-west-2"

# Your SSH public key (the matching private key is used by deploy.sh + ssh).
#   cat ~/.ssh/id_ed25519.pub
public_key = "ssh-ed25519 AAAA... you@host"

# Lock SSH + metrics (port 9090) to your own IP. Find it with: curl ifconfig.me
admin_cidr = "203.0.113.4/32"

# SIP signaling allowlist. Defaults to Vapi US signaling IPs (sip.vapi.ai).
# Override if your carrier differs.
# sip_cidrs = ["44.229.228.186/32", "44.238.177.138/32"]
#
# RTP media stays open (Vapi media IPs are dynamic; SGs can't filter source port).
# rtp_cidr = "0.0.0.0/0"

# Build host size. t4g.2xlarge (8 vCPU/32 GB) for fast first build.
# instance_type = "t4g.2xlarge"
