{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bridgefu.dev/schema/config-v1.json",
  "title": "Bridgefu configuration v1",
  "type": "object",
  "required": ["aws", "sip"],
  "properties": {
    "config_version": { "const": 1 },
    "aws": {
      "type": "object",
      "required": ["region"],
      "properties": {
        "region": { "type": "string", "minLength": 1 },
        "instance_id": { "type": "string" },
        "contact_flow_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "sip": {
      "type": "object",
      "properties": {
        "bind_ip": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "advertised_ip": { "type": "string" },
        "media_public_ip": { "type": "string" }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "properties": {
        "mode": { "enum": ["all-in-one", "gateway", "worker", "moq-relay"] },
        "max_concurrent_calls": { "type": "integer", "minimum": 1 },
        "setup_timeout_secs": { "type": "integer", "minimum": 1 },
        "drain_timeout_secs": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "persistence": {
      "type": "object",
      "properties": {
        "backend": { "enum": ["sqlite", "postgres", "postgresql", "memory"] },
        "database_url": { "type": "string", "minLength": 1 },
        "worker_id": {
          "type": "string",
          "format": "uuid",
          "not": { "const": "00000000-0000-0000-0000-000000000000" }
        },
        "allow_ephemeral_memory": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "backend": { "const": "memory" } },
            "required": ["backend"]
          },
          "then": {
            "required": ["allow_ephemeral_memory"],
            "properties": { "allow_ephemeral_memory": { "const": true } },
            "not": { "required": ["database_url"] }
          }
        },
        {
          "if": {
            "properties": { "backend": { "enum": ["postgres", "postgresql"] } },
            "required": ["backend"]
          },
          "then": { "required": ["database_url", "worker_id"] }
        }
      ],
      "additionalProperties": false
    },
    "api": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "bearer_token": { "type": "string" },
        "control_hmac_key": { "type": "string" },
        "static_tenant": { "type": "string" }
      },
      "additionalProperties": false
    },
    "broadcast": {
      "type": "object",
      "properties": {
        "default_transport": { "enum": ["moqt", "uctp-quic"] },
        "token_ttl_secs": { "type": "integer", "minimum": 1 },
        "max_active": { "type": "integer", "minimum": 1 },
        "public_endpoint": { "type": "string" },
        "token_secret": { "type": "string" }
      },
      "additionalProperties": false
    },
    "generic_bridge": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "sip_bind": { "type": "string" },
        "webrtc_ws_bind": { "type": "string" },
        "webrtc_whip_bind": { "type": "string" },
        "bearer_token": { "type": "string" }
      },
      "additionalProperties": false
    },
    "providers": { "type": "object" },
    "context": { "type": "object" },
    "tenants": { "type": "object" }
  }
}
